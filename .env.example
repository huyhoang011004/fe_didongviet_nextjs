# ============================================================
# CẤU HÌNH MÔI TRƯỜNG - FRONTEND DI ĐỘNG VIỆT
# ============================================================
# Sao chép file này thành .env.local và điền giá trị thực tế
# cp .env.example .env.local

# ---- API BACKEND ----
# URL của Backend API (bao gồm cả prefix /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Base URL của Backend (dùng để tạo đường dẫn ảnh đầy đủ)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000